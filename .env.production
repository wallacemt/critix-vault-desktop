# Produção — variáveis embutidas no bundle no momento do build
# ATENÇÃO: variáveis NEXT_PUBLIC_* são expostas ao client-side.
# Qualquer mudança aqui requer um novo 'bun run build:app'.

# URL da API do backend (Docker container na porta 8080)
# Se o Docker usa WSL2 no Windows, troque por http://host.docker.internal:8080
NEXT_PUBLIC_CRITIX_API_URL=http://localhost:8080
