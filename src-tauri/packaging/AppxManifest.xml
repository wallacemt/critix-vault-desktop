<?xml version="1.0" encoding="utf-8"?>
<!--
  AppxManifest.xml for Critix Vault Microsoft Store submission.

  Placeholders replaced by scripts/build-msix.ps1 and msix-build.yml:
    $PUBLISHER_CN$  : Publisher CN from Partner Center (e.g. "CN=XXXX-...")
    $VERSION$       : four-part version, e.g. 1.1.14.0
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:desktop2="http://schemas.microsoft.com/appx/manifest/desktop/windows10/2"
  IgnorableNamespaces="uap rescap desktop2">

  <Identity
    Name="WallaceSantana.CritixVault"
    Publisher="$PUBLISHER_CN$"
    Version="$VERSION$"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Critix Vault</DisplayName>
    <PublisherDisplayName>Wallace Santana</PublisherDisplayName>
    <Description>Gerenciador de pastas com midias avancado</Description>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Resources>
    <Resource Language="en-us" />
    <Resource Language="pt-br" />
  </Resources>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
    <PackageDependency
      Name="Microsoft.WindowsAppRuntime.1.4"
      MinVersion="4000.1010.1349.0"
      Publisher="CN=Microsoft Corporation, O=Microsoft Corporation, L=Redmond, S=Washington, C=US" />
  </Dependencies>

  <Applications>
    <Application
      Id="CRITIXVAULT"
      Executable="critix-vault.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        BackgroundColor="transparent"
        DisplayName="CritixVault"
        Description="CritixVault"
        Square150x150Logo="Assets\CRITIXVAULT-Square150x150Logo.png"
        Square44x44Logo="Assets\CRITIXVAULT-Square44x44Logo.png">
        <uap:DefaultTile
          Wide310x150Logo="Assets\CRITIXVAULT-Wide310x150Logo.png"
          Square310x310Logo="Assets\CRITIXVAULT-Square310x310Logo.png"
          Square71x71Logo="Assets\CRITIXVAULT-Square71x71Logo.png" />
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Required for Desktop Bridge apps that spawn Win32 child processes (node.exe) -->
    <rescap:Capability Name="runFullTrust" />
    <!--
      Required for WebView2 to connect to http://127.0.0.1:1422 (the embedded Next.js server).
      WebView2 renderer processes run inside an AppContainer that blocks loopback by default,
      even when the host process has runFullTrust. This capability lifts that restriction.
      Approved for MS Store submission (non-restricted).
    -->
    <Capability Name="privateNetworkClientServer" />
  </Capabilities>

  <!--
    Package-level firewall rule for the bundled node.exe.
    Windows Firewall silently blocks outbound TCP from node.exe for non-admin MSIX users
    until a rule is created. Declaring it here causes Windows to register the rule at
    install time — no admin prompt, no manual interaction required.
    Requires runFullTrust (already declared). Supported since Windows 10 1709.
  -->
  <Extensions>
    <desktop2:Extension Category="windows.firewallRules">
      <desktop2:FirewallRules Executable="resources\server\node.exe">
        <desktop2:Rule Direction="out" IPProtocol="TCP" Profile="all" />
      </desktop2:FirewallRules>
    </desktop2:Extension>
  </Extensions>

</Package>
