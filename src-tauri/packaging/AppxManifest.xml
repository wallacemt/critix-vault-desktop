<?xml version="1.0" encoding="utf-8"?>
<!--
  AppxManifest.xml for Critix Vault Microsoft Store submission.

  Before packaging, replace the following placeholders:
    $PUBLISHER_CN$  — full Publisher CN string from your Partner Center account
                      (e.g. "CN=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX")
    $VERSION$       — four-part version matching tauri.conf.json (e.g. 1.1.13.0)

  The CI workflow (msix-build.yml) substitutes these automatically via
  the MSIX_PUBLISHER_CN and VERSION secrets/inputs.
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <Identity
    Name="WallaceSantana.CritixVault"
    Publisher="$PUBLISHER_CN$"
    Version="$VERSION$"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Critix Vault</DisplayName>
    <PublisherDisplayName>Wallace Santana</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersion="10.0.99999.0" />
  </Dependencies>

  <Resources>
    <Resource Language="pt-BR" />
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application
      Id="critix_vault"
      Executable="critix-vault.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Critix Vault"
        Description="Seu gerenciador de pastas com medias favorito"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" BackgroundColor="#1a1a1a" />
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Required for desktop bridge (full-trust process) -->
    <rescap:Capability Name="runFullTrust" />
    <!-- Network access for the embedded Next.js server -->
    <Capability Name="internetClient" />
    <Capability Name="privateNetworkClientServer" />
  </Capabilities>

</Package>
