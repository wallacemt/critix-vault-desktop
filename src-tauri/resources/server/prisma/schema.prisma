// Critix Vault Database Schema
generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
}

// Folder Model
model Folder {
    id         String   @id @default(uuid())
    name       String
    path       String   @unique
    mediaCount Int      @default(0)
    addedAt    DateTime @default(now())

    movies Movie[]
    series Series[]

    @@map("folders")
}

// Movie Model
model Movie {
    id            String  @id
    title         String
    originalTitle String?
    overview      String?
    poster        String?
    backdrop      String?
    rating        Float?
    year          Int?
    releaseDate   String?
    status        String // MATCHED, UNMATCHED, ERROR
    type          String  @default("MOVIE")
    filePath      String
    duration      Int?
    trailer       String?

    // New TMDB fields
    genres     String? // JSON array of genre names
    imdbId     String?
    tagline    String?
    budget     Int?
    revenue    Int?
    voteCount  Int?
    popularity Float?
    images     String? // JSON array of image URLs
    videos     String? // JSON array of video objects
    cast       String? // JSON array of cast member objects
    crew       String? // JSON array of crew member objects

    folderId String
    folder   Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([folderId])
    @@index([status])
    @@map("movies")
}

// Series Model
model Series {
    id               String  @id
    title            String
    originalTitle    String?
    overview         String?
    poster           String?
    backdrop         String?
    rating           Float?
    year             Int?
    firstAirDate     String?
    lastAirDate      String?
    status           String // MATCHED, UNMATCHED, ERROR
    type             String  @default("SERIES")
    filePath         String
    folderPath       String?
    numberOfSeasons  Int     @default(0)
    numberOfEpisodes Int     @default(0)
    duration         Int?
    trailer          String?

    // New TMDB fields
    genres              String? // JSON array of genre names
    imdbId              String?
    tagline             String?
    voteCount           Int?
    popularity          Float?
    images              String? // JSON array of image URLs
    videos              String? // JSON array of video objects
    cast                String? // JSON array of cast member objects
    crew                String? // JSON array of crew member objects
    networks            String? // JSON array of network names
    productionCompanies String? // JSON array of production companies

    folderId String
    folder   Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

    seasons Season[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([folderId])
    @@index([status])
    @@map("series")
}

// Season Model
model Season {
    id                 String  @id @default(uuid())
    seasonNumber       Int
    name               String
    overview           String?
    poster             String?
    episodeCount       Int     @default(0)
    available          Boolean @default(false)
    downloadedEpisodes Int     @default(0)

    seriesId String
    series   Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)

    episodes Episode[]

    @@unique([seriesId, seasonNumber])
    @@index([seriesId])
    @@map("seasons")
}

// Episode Model
model Episode {
    id            String  @id @default(uuid())
    episodeNumber Int
    seasonNumber  Int
    title         String
    overview      String?
    stillPath     String?
    airDate       String?
    duration      Int?
    filePath      String?
    available     Boolean @default(false)

    seasonId String
    season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

    @@unique([seasonId, episodeNumber])
    @@index([seasonId])
    @@map("episodes")
}

// Watch History Model
model WatchHistory {
    id            String   @id @default(uuid())
    mediaId       String?
    mediaType     String // MOVIE, SERIES
    episodeId     String?
    seasonNumber  Int?
    episodeNumber Int?
    watchedAt     DateTime @default(now())
    progress      Float? // 0-100
    completed     Boolean  @default(false)

    @@index([mediaId])
    @@index([watchedAt])
    @@map("watch_history")
}

// User Action History Model
model UserActionHistory {
    id         String   @id @default(uuid())
    actionType String // FOLDER_VIEW, MOVIE_VIEW, SERIES_VIEW , TAB_VIEW
    folderId   String?
    mediaId    String?
    mediaType  String? // MOVIE, SERIES
    timestamp  DateTime @default(now())

    @@index([actionType])
    @@index([timestamp])
    @@map("user_action_history")
}
