{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Critix Vault",
  "version": "1.1.9",
  "identifier": "com.wallace.critix-vault",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build && node scripts/prepare-build.mjs",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Critix Vault",
        "width": 1400,
        "height": 900,
        "minWidth": 1400,
        "minHeight": 900,
        "maxWidth": 1400,
        "maxHeight": 900,
        "resizable": false,
        "maximizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:1422; connect-src 'self' http://127.0.0.1:* http://localhost:* https://* wss://api-critix.wallacedev.com.br http://localhost:8080 ws://localhost:8080 https://api-critix.wallacedev.com.br; img-src 'self' https://image.tmdb.org data: blob: http://127.0.0.1:* http://localhost:* https://api-critix.wallacedev.com.br http://localhost:8080; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com;"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": ["https://github.com/wallacemt/critix-vault-desktop/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzM0M1ODZGNTlBNDU0RjMKUldUelZLUlpiMWc4MHhRN2RKNlIzaC9jdTQ2d1lhSzltY3V5eE8vNnlQNlJITndxZjZ5byt5RU0K"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "resources": ["resources/server"],
    "category": "Productivity",
    "shortDescription": "Biblioteca local de medias aprimorada.",
    "longDescription": "O Critix Vault organiza as pastas que voce ja tem no computador e transforma isso em uma biblioteca bonita, rapida e facil de navegar.",
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installerHooks": "installer-hooks.nsh"
      }
    }
  }
}
