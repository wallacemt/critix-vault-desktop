{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Critix Vault",
  "version": "0.1.0",
  "identifier": "com.walla.critix-vault",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build && node scripts/prepare-build.mjs",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Critix Vault",
        "width": 1400,
        "height": 900,
        "minWidth": 1400,
        "minHeight": 900,
        "maxWidth": 1400,
        "maxHeight": 900,
        "resizable": false,
        "maximizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:1422; connect-src 'self' http://127.0.0.1:* http://localhost:* https://*; img-src 'self' https://image.tmdb.org data: blob: http://127.0.0.1:* http://localhost:*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["resources/server"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
